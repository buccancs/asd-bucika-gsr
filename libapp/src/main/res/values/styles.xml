<resources>

    <style name="base_dialog" parent="android:style/Theme.Dialog">
 <item name="android:statusBarColor">#00000000</item> <!-- bar -->
 <item name="android:windowFrame">@null</item> <!-- -->
 <item name="android:windowIsFloating">false</item> <!-- activity -->
 <item name="android:windowNoTitle">true</item> <!-- -->
 <item name="android:windowIsTranslucent">false</item> <!-- -->
 <item name="android:windowBackground">#00000000</item><!-- - -->
        dialog
    </style>

 <!-- dialog style -->
    <style name="transparent_dialog" parent="base_dialog">
        dialog
    </style>

    input
    <style name="input_dialog" parent="base_dialog">
        <item name="android:windowSoftInputMode">stateAlwaysVisible|adjustPan</item>
    </style>




    <style name="ToolbarTheme" parent="AppTheme">
        <item name="android:textColorPrimary">@android:color/white</item>
        <item name="android:textColorSecondary">@android:color/white</item>
        <item name="colorControlActivated">@android:color/white</item>
    </style>

    <style name="InfoDialog" parent="android:style/Theme.Dialog">
        <item name="android:background">#00000000</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
    </style>

    <style name="TextInputDialog" parent="@android:style/Theme.Dialog">
 <item name="android:windowFrame">@null</item> <!-- -->
 <item name="android:windowIsFloating">true</item> <!-- activity -->
 <item name="android:windowNoTitle">true</item> <!-- -->
 <item name="android:windowIsTranslucent">false</item><!-- -->
 <item name="android:windowBackground">@android:color/transparent</item><!-- - -->
        dialog
        <item name="android:windowSoftInputMode">stateAlwaysVisible|adjustPan</item>
    </style>

    <style name="DefaultDialog" parent="@android:style/Theme.Dialog">
 <item name="android:windowFrame">@null</item> <!-- -->
 <item name="android:windowIsFloating">false</item> <!-- activity -->
 <item name="android:windowNoTitle">true</item> <!-- -->
 <item name="android:windowIsTranslucent">false</item><!-- -->
 <item name="android:windowBackground">@android:color/transparent</item><!-- - -->
        dialog
    </style>

 <!-- dialog style -->
    <style name="TransparentDialog" parent="AppTheme">
 <item name="android:windowFrame">@null</item> <!-- -->
 <item name="android:windowIsFloating">false</item> <!-- activity -->
 <item name="android:windowNoTitle">true</item> <!-- -->
 <item name="android:windowIsTranslucent">true</item> <!-- -->
 <item name="android:windowBackground">@android:color/transparent</item><!-- - -->
        dialog
        <item name="android:statusBarColor">@android:color/transparent</item>
    </style>

    <style name="cameraSetSwitch" parent="Theme.AppCompat.Light">
        <item name="android:background">@null</item>
        <item name="android:thumb">@drawable/switch_thumb_ios</item>
        <item name="track">@drawable/switch_track_ios</item>
    </style>
</resources>
